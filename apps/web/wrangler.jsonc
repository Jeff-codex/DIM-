{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dim-web",
  "main": "worker.js",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "DIM_WORKFLOW_ENV": "editorial_production",
    "EDITORIAL_ADMIN_ALLOWED_EMAILS": "magazine@depthintelligence.kr",
    "EDITORIAL_ADMIN_ALLOWED_DOMAIN": "depthintelligence.kr",
    "TURNSTILE_SITE_KEY": "0x4AAAAAACtgY9d0EdquDH-9",
    "OPENAI_SIGNAL_MODEL": "gpt-5-mini",
    "OPENAI_DRAFT_MODEL": "gpt-5.4",
    "EDITORIAL_DRAFT_GENERATOR_URL": "https://dim-production.up.railway.app",
    "SUBMIT_RATE_LIMIT_WINDOW_SECONDS": "900",
    "SUBMIT_RATE_LIMIT_MAX_ATTEMPTS": "5"
  },
  "d1_databases": [
    {
      "binding": "EDITORIAL_DB",
      "database_name": "dim-editorial-prod",
      "database_id": "525a6139-746c-40b2-be57-c4e12574f6d8",
      "migrations_dir": "db/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "INTAKE_BUCKET",
      "bucket_name": "dim-intake-prod"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "EDITORIAL_QUEUE",
        "queue": "dim-editorial-prod"
      }
    ]
  },
  "routes": [
    {
      "pattern": "depthintelligence.kr/*",
      "zone_name": "depthintelligence.kr"
    },
    {
      "pattern": "www.depthintelligence.kr/*",
      "zone_name": "depthintelligence.kr"
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "env": {
    "editorial_preview": {
      "vars": {
        "DIM_WORKFLOW_ENV": "editorial_preview",
        "EDITORIAL_PREVIEW_BYPASS": "enabled",
        "EDITORIAL_PREVIEW_ADMIN_EMAIL": "preview-editor@depthintelligence.kr",
        "EDITORIAL_ADMIN_ALLOWED_EMAILS": "preview-editor@depthintelligence.kr,magazine@depthintelligence.kr",
        "EDITORIAL_ADMIN_ALLOWED_DOMAIN": "depthintelligence.kr",
        "TURNSTILE_SITE_KEY": "",
        "OPENAI_SIGNAL_MODEL": "gpt-5-mini",
        "OPENAI_DRAFT_MODEL": "gpt-5.4",
        "EDITORIAL_DRAFT_GENERATOR_URL": "https://dim-production.up.railway.app",
        "SUBMIT_RATE_LIMIT_WINDOW_SECONDS": "300",
        "SUBMIT_RATE_LIMIT_MAX_ATTEMPTS": "20"
      },
      "d1_databases": [
        {
          "binding": "EDITORIAL_DB",
          "database_name": "dim-editorial-preview",
          "database_id": "3ff20a8d-4e74-4d94-a5c7-a306f8c2b773",
          "migrations_dir": "db/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "INTAKE_BUCKET",
          "bucket_name": "dim-intake-preview"
        }
      ],
      "queues": {
        "producers": [
          {
            "binding": "EDITORIAL_QUEUE",
            "queue": "dim-editorial-preview"
          }
        ]
      }
    },
    "production_candidate": {
      "vars": {
        "DIM_WORKFLOW_ENV": "editorial_production",
        "EDITORIAL_ADMIN_ALLOWED_EMAILS": "magazine@depthintelligence.kr",
        "EDITORIAL_ADMIN_ALLOWED_DOMAIN": "depthintelligence.kr",
        "TURNSTILE_SITE_KEY": "0x4AAAAAACtgzkb_9fT54WDA",
        "OPENAI_SIGNAL_MODEL": "gpt-5-mini",
        "OPENAI_DRAFT_MODEL": "gpt-5.4",
        "EDITORIAL_DRAFT_GENERATOR_URL": "https://dim-production.up.railway.app",
        "SUBMIT_RATE_LIMIT_WINDOW_SECONDS": "900",
        "SUBMIT_RATE_LIMIT_MAX_ATTEMPTS": "5"
      },
      "d1_databases": [
        {
          "binding": "EDITORIAL_DB",
          "database_name": "dim-editorial-candidate",
          "database_id": "cb1047f3-d686-49d6-a257-0da8a92f1399",
          "migrations_dir": "db/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "INTAKE_BUCKET",
          "bucket_name": "dim-intake-candidate"
        }
      ],
      "queues": {
        "producers": [
          {
            "binding": "EDITORIAL_QUEUE",
            "queue": "dim-editorial-candidate"
          }
        ]
      }
    }
  },
  "observability": {
    "enabled": true
  }
}
