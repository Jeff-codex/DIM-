{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare-content": "node ./scripts/generate-content.mjs",
    "predev": "npm run prepare-content",
    "prebuild": "npm run prepare-content",
    "prelint": "npm run prepare-content",
    "dev": "next dev",
    "build": "next build --webpack",
    "build:static": "node ./scripts/build-static.mjs",
    "slug:audit": "node --experimental-strip-types ./scripts/slug-audit.ts",
    "slug:backfill": "node --experimental-strip-types ./scripts/slug-backfill.ts",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "preview:serve-static": "node ./scripts/serve-static-preview.mjs",
    "preview:deploy": "node ./scripts/deploy-pages-preview.mjs",
    "preview:editorial-runtime": "node ./scripts/deploy-runtime-env.mjs --env editorial_preview && node ./scripts/deploy-editorial-consumer.mjs --env editorial_preview",
    "preview:production-candidate": "node ./scripts/deploy-runtime-env.mjs --env production_candidate && node ./scripts/deploy-editorial-consumer.mjs --env production_candidate",
    "smoke:editorial-runtime": "node ./scripts/smoke-editorial-runtime.mjs",
    "smoke:production-candidate": "node ./scripts/smoke-production-hardening.mjs --mode=candidate --base-url=https://dim-web-production_candidate.depthintelligence.workers.dev",
    "smoke:production-runtime": "node ./scripts/smoke-production-hardening.mjs --mode=production --base-url=https://depthintelligence.kr",
    "deploy": "node ./scripts/deploy-production-runtime.mjs && node ./scripts/deploy-editorial-consumer.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf-typegen:editorial-preview": "wrangler types --env editorial_preview --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "wrangler": "^4.72.0"
  }
}
